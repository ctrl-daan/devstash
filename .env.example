# Copy to .env and fill in real values. Never commit .env.
#
# Neon PostgreSQL connection string (development branch).
# Get it from the Neon dashboard → Connection Details.
# Use the pooled connection string for the app runtime; a direct
# (unpooled) string is recommended when running migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"